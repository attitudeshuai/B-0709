{
  "manifest_version": 3,
  "name": "WordVault Synchronized",
  "version": "1.0",
  "description": "Cross-context synced vocabulary builder.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "commands"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.dictionaryapi.dev/*",
    "https://translate.googleapis.com/*",
    "https://translate.google.com/*",
    "https://api.mymemory.translated.net/*"
  ],
  "commands": {
    "translate-word": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Alt+Q"
      },
      "description": "Translate selection"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "My Vocabulary"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"], 
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
